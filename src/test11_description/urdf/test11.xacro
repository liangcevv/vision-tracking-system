<?xml version="1.0" ?>
<robot name="test11" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find test11_description)/urdf/materials.xacro" />
<xacro:include filename="$(find test11_description)/urdf/test11.trans" />
<xacro:include filename="$(find test11_description)/urdf/test11.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="0.14595696730287228 -0.0069782300277070365 0.09831870104649193" rpy="0 0 0"/>
    <mass value="5.518968459018653"/>
    <inertia ixx="0.04418" iyy="0.047195" izz="0.050954" ixy="4.8e-05" iyz="-0.000134" ixz="-0.004789"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="right_wheel">
  <inertial>
    <origin xyz="-4.15727808011912e-08 -0.011017473898217722 4.116808957482787e-07" rpy="0 0 0"/>
    <mass value="2.9595069273045143"/>
    <inertia ixx="0.006631" iyy="0.012759" izz="0.006631" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.184181 0.102076 -0.084751" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.184181 0.102076 -0.084751" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/right_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="left_wheel">
  <inertial>
    <origin xyz="-4.157311728203439e-08 0.011018083823621738 4.1168070347152863e-07" rpy="0 0 0"/>
    <mass value="2.959506927354149"/>
    <inertia ixx="0.006631" iyy="0.012759" izz="0.006631" ixy="-0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.184181 -0.088924 -0.084751" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.184181 -0.088924 -0.084751" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/left_wheel_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="camera_link">
  <inertial>
    <origin xyz="-0.00961500633557899 -1.0970586762226384e-05 0.004911649302484139" rpy="0 0 0"/>
    <mass value="0.033600494879184276"/>
    <inertia ixx="6e-06" iyy="3e-06" izz="3e-06" ixy="0.0" iyz="-0.0" ixz="1e-06"/>
  </inertial>
  <visual>
    <origin xyz="-0.245001 0.006564 -0.145532" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/camera_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.245001 0.006564 -0.145532" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/camera_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="laser_link">
  <inertial>
    <origin xyz="0.00454065771143683 -0.01939682662834952 0.005694455210610745" rpy="0 0 0"/>
    <mass value="0.1616483023051331"/>
    <inertia ixx="0.000129" iyy="5.6e-05" izz="0.000143" ixy="1e-06" iyz="-2.6e-05" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.162817 -0.0 -0.060341" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.162817 -0.0 -0.060341" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/lidar_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="base_footprint">
  <!-- 注释掉inertial参数，因为KDL不支持根链接有惯性参数 -->
  <!--
  <inertial>
    <origin xyz="0.00022108314410562713 -0.006999695037297943 -0.0014837870730470028" rpy="0 0 0"/>
    <mass value="0.0018496126748009944"/>
    <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="-0.0"/>
  </inertial>
  -->
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/base_footprint_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://test11_description/meshes/base_footprint_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="j1" type="fixed">
  <origin xyz="0.184181 -0.102076 0.084751" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="right_wheel"/>
  <axis xyz="-0.0 1.0 0.0"/>
</joint>

<joint name="j2" type="fixed">
  <origin xyz="0.184181 0.088924 0.084751" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="left_wheel"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<joint name="j3" type="fixed">
  <origin xyz="0.245001 -0.006564 0.145532" rpy="-1.5708 0 -1.5708"/>
  <parent link="base_link"/>
  <child link="camera_link"/>
</joint>

<joint name="j4" type="fixed">
  <origin xyz="0.162817 0.0 0.060341" rpy="0 0 -1.5708"/>
  <parent link="base_link"/>
  <child link="laser_link"/>
</joint>

<joint name="j6" type="fixed">
  <origin xyz="-0.15 0 0" rpy="0 0 0"/>
  <parent link="base_footprint"/>
  <child link="base_link"/>
</joint>

</robot>
